# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://optionthropic:optionthropic_secret@localhost:5432/optionthropic

# ─── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Data Source ───────────────────────────────────────────────────────────────
# Options: NSE | ZERODHA | ANGEL
DATA_SOURCE=NSE
NSE_API_URL=https://www.nseindia.com

ZERODHA_API_KEY=your_zerodha_api_key
# Used only to run generate_token.py — never commit real secret
ZERODHA_API_SECRET=your_zerodha_api_secret
ZERODHA_ACCESS_TOKEN=your_zerodha_access_token

ANGEL_API_KEY=your_angel_api_key
ANGEL_CLIENT_ID=your_angel_client_id
ANGEL_PASSWORD=your_angel_password
ANGEL_TOTP_SECRET=your_angel_totp_secret

# ─── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# Options: openai | anthropic
AI_PROVIDER=openai

# ─── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/optionthropic-alerts

# ─── Cognito ───────────────────────────────────────────────────────────────────
# Set USE_COGNITO=true in production; false uses local JWT
USE_COGNITO=false
COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
COGNITO_CLIENT_ID=your_cognito_client_id

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_USE_COGNITO=false
NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=your_cognito_client_id
NEXT_PUBLIC_AWS_REGION=ap-south-1

# ─── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
POLL_INTERVAL_SECONDS=60
